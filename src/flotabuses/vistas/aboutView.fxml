<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="420.0" prefWidth="500.0"
            stylesheets="@../utils/FlotaBuses.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="flotabuses.controladores.AboutController">
   <children>
      <VBox alignment="CENTER" spacing="12.0"
            AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0"
            AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="20.0">
         <children>

            <!-- Logo / título principal -->
            <Label text="Flotilla de Buses" styleClass="about-title">
               <font><Font name="System Bold" size="26.0" /></font>
            </Label>

            <Label text="Sistema de Gestión de Agencia Turística" styleClass="about-subtitle">
               <font><Font size="13.0" /></font>
            </Label>

            <Separator prefWidth="400.0">
               <VBox.margin><Insets top="6.0" bottom="6.0" /></VBox.margin>
            </Separator>

            <!-- Tecnologías -->
            <Label text="Desarrollado con  Java 21 + JavaFX 21" styleClass="about-info" />
            <Label text="Estructuras de datos personalizadas (ABB, Lista Doble, Matriz Ortogonal)" styleClass="about-info"
                   wrapText="true" maxWidth="430.0" textAlignment="CENTER" />

            <Separator prefWidth="400.0">
               <VBox.margin><Insets top="6.0" bottom="6.0" /></VBox.margin>
            </Separator>

            <!-- Créditos -->
            <Label text="Desarrolladores" styleClass="about-section">
               <font><Font name="System Bold" size="14.0" /></font>
            </Label>

            <VBox alignment="CENTER" spacing="4.0">
               <Label text="José Pablo Fabián Herrera García" styleClass="about-dev-name">
                  <font><Font name="System Bold" size="12.0" /></font>
               </Label>
               <Label text="Carné: 9490-24-688" styleClass="about-dev-carne" />
            </VBox>

            <VBox alignment="CENTER" spacing="4.0">
               <Label text="Josué Damián García Quiñonez" styleClass="about-dev-name">
                  <font><Font name="System Bold" size="12.0" /></font>
               </Label>
               <Label text="Carné: 9490-24-4256" styleClass="about-dev-carne" />
            </VBox>

            <Separator prefWidth="400.0">
               <VBox.margin><Insets top="6.0" bottom="6.0" /></VBox.margin>
            </Separator>

            <!-- Universidad -->
            <Label text="Universidad Mariano Gálvez de Guatemala" styleClass="about-info" />
            <Label text="Ingeniería en Sistemas — Estructura de Datos" styleClass="about-info" />
            <Label text="Semestre 2025" styleClass="about-info" />

            <Separator prefWidth="400.0">
               <VBox.margin><Insets top="6.0" bottom="2.0" /></VBox.margin>
            </Separator>

            <!-- Botón regresar -->
            <Button onAction="#regresarMenu" text="Regresar al Menú"
                    prefWidth="200.0" defaultButton="true">
               <VBox.margin><Insets top="6.0" /></VBox.margin>
            </Button>

         </children>
         <padding><Insets top="10.0" /></padding>
      </VBox>
   </children>
</AnchorPane>
