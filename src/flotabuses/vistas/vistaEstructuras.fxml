<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Group?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="flotabuses.controladores.VisualizadorEstructurasController">
   <children>

      <!-- Fondo decorativo — mismo estilo que todos los modulos -->
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#84b4d4" height="710.0"
                 layoutX="284.0" stroke="#84b4d4" strokeType="INSIDE" width="820.0" />
      <Ellipse fill="#dde4ef" layoutX="193.0" layoutY="146.0"
               radiusX="357.0" radiusY="422.0" rotate="-36.9"
               stroke="#dde4ef" strokeType="INSIDE" />
      <Ellipse fill="#54a4d3" layoutX="219.0" layoutY="595.0"
               radiusX="374.0" radiusY="213.0" rotate="-167.5"
               stroke="#54a4d3" strokeType="INSIDE" />

      <!-- Panel lateral izquierdo rotado con nombre del modulo -->
      <Pane layoutX="-123.0" layoutY="-127.0" prefHeight="377.0" prefWidth="123.0"
            rotate="90.0" style="-fx-background-color: #ddaca0; -fx-background-radius: 100 100 50 50;">
         <children>
            <ImageView fitHeight="76.0" fitWidth="69.0" layoutX="40.0" layoutY="48.0"
                       pickOnBounds="true" preserveRatio="true" rotate="-90.0">
               <image>
                  <Image url="@../images/Icon.png" />
               </image>
            </ImageView>
            <Label layoutX="2.0" layoutY="77.0" rotate="-90.0" text="Visualizador" />
         </children>
      </Pane>

      <!-- Boton volver al menu principal (icono go-back) -->
      <ImageView fitHeight="81.0" fitWidth="76.0" layoutX="22.0" layoutY="595.0"
                 onMouseClicked="#volverMenu" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../images/go-back.png" />
         </image>
      </ImageView>

      <!-- Botones de accion — estilo button1 identico al resto de pantallas -->
      <HBox layoutX="174.0" layoutY="597.0" prefHeight="95.0" prefWidth="300.0">
         <children>
            <Button fx:id="btnRefrescar" contentDisplay="TOP" mnemonicParsing="false"
                    onAction="#refrescar" prefHeight="90.0" prefWidth="120.0"
                    styleClass="button1" stylesheets="@../utils/FlotaBuses.css"
                    text="Refrescar">
               <graphic>
                  <ImageView fitHeight="65.0" fitWidth="65.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/Save.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
         </children>
      </HBox>

      <!-- TabPane con las tres estructuras de datos -->
      <TabPane tabClosingPolicy="UNAVAILABLE"
               layoutX="125.0" layoutY="5.0"
               prefHeight="580.0" prefWidth="965.0"
               stylesheets="@../utils/FlotaBuses.css">
         <tabs>

            <!-- Tab 1: Arbol Binario de Busqueda (Clientes) -->
            <Tab text="Arbol Binario — Clientes">
               <content>
                  <ScrollPane fitToWidth="false" fitToHeight="false"
                              hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                     <content>
                        <Group>
                           <children>
                              <Canvas fx:id="canvasArbol" width="1100.0" height="530.0"/>
                           </children>
                        </Group>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>

            <!-- Tab 2: Lista Doblemente Enlazada (Buses) -->
            <Tab text="Lista Doble — Buses">
               <content>
                  <ScrollPane fitToWidth="false" fitToHeight="false"
                              hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                     <content>
                        <Group>
                           <children>
                              <Canvas fx:id="canvasLista" width="1800.0" height="220.0"/>
                           </children>
                        </Group>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>

            <!-- Tab 3: Matriz Ortogonal (Asignaciones bus-destino) -->
            <Tab text="Matriz Ortogonal — Asignaciones">
               <content>
                  <ScrollPane fitToWidth="false" fitToHeight="false"
                              hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                     <content>
                        <Group>
                           <children>
                              <Canvas fx:id="canvasMatriz" width="1400.0" height="530.0"/>
                           </children>
                        </Group>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>

         </tabs>
      </TabPane>

   </children>
</AnchorPane>
