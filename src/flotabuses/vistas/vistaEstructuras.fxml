<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.Group?>
<?import javafx.scene.layout.HBox?>

<AnchorPane minHeight="600.0" minWidth="900.0" prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="flotabuses.controladores.VisualizadorEstructurasController">
   <children>

      <!-- Barra de herramientas superior -->
      <HBox alignment="CENTER_LEFT" layoutX="0.0" layoutY="0.0"
            prefWidth="1100.0" prefHeight="38.0" spacing="12.0"
            style="-fx-background-color: #2c3e50; -fx-padding: 5 10 5 10;">
         <children>
            <Label text="Visualizador de Estructuras de Datos"
                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
            <Button onAction="#refrescar" text="Refrescar"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
            <Button onAction="#volverMenu" text="Menu Principal"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
         </children>
      </HBox>

      <!-- Panel de pestanas con los tres visualizadores -->
      <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
               AnchorPane.topAnchor="38.0" AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <tabs>

            <!-- Tab 1: Arbol Binario de Busqueda (Clientes) -->
            <Tab text="Arbol Binario — Clientes">
               <content>
                  <ScrollPane fitToWidth="false" fitToHeight="false"
                              hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                     <content>
                        <Group>
                           <children>
                              <Canvas fx:id="canvasArbol" width="1100.0" height="550.0"/>
                           </children>
                        </Group>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>

            <!-- Tab 2: Lista Doblemente Enlazada (Buses) -->
            <Tab text="Lista Doblemente Enlazada — Buses">
               <content>
                  <ScrollPane fitToWidth="false" fitToHeight="false"
                              hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                     <content>
                        <Group>
                           <children>
                              <Canvas fx:id="canvasLista" width="1800.0" height="220.0"/>
                           </children>
                        </Group>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>

            <!-- Tab 3: Matriz Ortogonal (Asignaciones bus-destino) -->
            <Tab text="Matriz Ortogonal — Asignaciones">
               <content>
                  <ScrollPane fitToWidth="false" fitToHeight="false"
                              hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
                     <content>
                        <Group>
                           <children>
                              <Canvas fx:id="canvasMatriz" width="1400.0" height="600.0"/>
                           </children>
                        </Group>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>

         </tabs>
      </TabPane>
   </children>
</AnchorPane>
